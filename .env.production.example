# ============================================================
# Gold Tier Autonomous Employee - Production Configuration
# ============================================================
# Copy this file to .env and configure with your settings
# NEVER commit .env to version control

# ============================================================
# CORE SETTINGS
# ============================================================
ENABLE_AUTONOMOUS_LOOP=true
LOOP_INTERVAL_SECONDS=60

# ============================================================
# ODOO CONFIGURATION
# ============================================================
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=change-this-password

# ============================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================
# Gmail setup:
# 1. Enable 2FA on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character App Password below

EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_FROM_NAME=AI Employee

# ============================================================
# SOCIAL MEDIA MONITORING (Optional)
# ============================================================

# Facebook
FACEBOOK_MONITORING_ENABLED=false
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Twitter/X
TWITTER_MONITORING_ENABLED=false
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Instagram
INSTAGRAM_MONITORING_ENABLED=false
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ============================================================
# HEALTH MONITORING
# ============================================================
# HTTP port for health check dashboard
HEALTH_CHECK_PORT=8080

# ============================================================
# ALERTING
# ============================================================
# Email alerts for system issues
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO=admin@example.com

# Alert thresholds
ALERT_ERROR_RATE_THRESHOLD=10.0
ALERT_CPU_THRESHOLD=90.0
ALERT_MEMORY_THRESHOLD=90.0
ALERT_NO_ITERATION_SECONDS=300
ALERT_COOLDOWN_MINUTES=30

# ============================================================
# LOG MANAGEMENT
# ============================================================
# Log retention and rotation settings
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS_AGE_DAYS=7
LOG_MAX_SIZE_MB=100

# ============================================================
# SECURITY (Optional)
# ============================================================
# Kill switch file path (create this file to stop the system)
KILL_SWITCH_FILE=kill_switch.txt
